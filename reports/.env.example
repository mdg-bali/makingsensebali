# Making Sense Bali Reporter — secrets and per-deployment config
#
# Copy this file to .env and fill in real values:
#   cp .env.example .env
#
# .env is gitignored. Never commit secrets.

# --- Evolution API auth key ---
# Generate a long random string. Both Evolution and the bot use this.
#   openssl rand -hex 32
EVOLUTION_API_KEY=replace-me-with-a-long-random-hex-string

# --- Postgres password (for Evolution API's database) ---
# Generate another random string:
#   openssl rand -hex 16
POSTGRES_PASSWORD=replace-me-with-another-random-string

# --- Dashboard auth ---
# Username can stay 'admin'. Generate a strong password:
#   openssl rand -hex 16
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=replace-me-with-a-third-random-string

# --- Anthropic API key (optional vision fallback) ---
# Only needed if AQ_VISION_BACKEND=haiku on the M1 worker.
# ANTHROPIC_API_KEY=sk-ant-...
